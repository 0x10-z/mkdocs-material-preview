{
    "name": "mkdocs-material-preview",
    "displayName": "MkDocs Material Preview",
    "description": "Material for MkDocs component support in VS Code Markdown preview (admonitions, tabs, code enhancements)",
    "version": "0.1.3",
    "author": "Iker Ocio Zuazo (0x10)",
    "publisher": "0x10",
    "license": "MIT",
    "icon": "media/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/0x10-z/mkdocs-material-preview"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./media/mkdocs-material.css"
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.0.0",
        "@types/vscode": "^1.75.0",
        "typescript": "^5.3.0"
    }
}
