{
    "name": "mkdocs-material-preview",
    "displayName": "MkDocs Material Preview",
    "description": "Material for MkDocs & Zensical preview — no MkDocs, Python, or server needed. Just use VS Code's built-in Markdown preview (Ctrl+Shift+V). Admonitions, tabs, and code enhancements.",
    "version": "0.1.7",
    "author": "Iker Ocio Zuazo (0x10)",
    "publisher": "0x10",
    "license": "MIT",
    "icon": "media/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/0x10-z/mkdocs-material-preview"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Other"
    ],
    "keywords": [
        "mkdocs",
        "material",
        "zensical",
        "markdown",
        "preview",
        "admonition"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "markdown.markdownItPlugins": true,
        "markdown.previewStyles": [
            "./media/mkdocs-material.css"
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "test": "vitest run"
    },
    "devDependencies": {
        "@types/markdown-it": "^14.0.0",
        "@types/vscode": "^1.75.0",
        "markdown-it": "^14.1.1",
        "typescript": "^5.3.0",
        "vitest": "^4.1.0"
    }
}
